# Local development overrides for `flue dev` / `wrangler dev`.
# Copy this file to `.dev.vars` and replace the placeholder values.
# `.dev.vars` is gitignored — never commit real secrets.
#
# How environments work here: `flue build` flattens `wrangler.jsonc` into a
# single-environment deploy config (no wrangler `env.*` blocks), so the `vars`
# in `wrangler.jsonc` ARE the production values. This file is the dev counterpart:
# anything set here overrides those `vars` during local dev.
#
# Docs: https://developers.cloudflare.com/workers/configuration/secrets/

ENVIRONMENT=dev

# Browser origin allowed to call this Worker cross-origin (the front-app SPA).
# localhost:5174 (vite dev) / :4174 (vite preview) are always allowed in code;
# set this to the deployed SPA origin in production.
WEB_APP_ORIGIN=http://localhost:5174

# Inbound API key. HACKATHON: currently UNUSED — the auth guard was removed
# from /agents/*, /workflows/* and /runs/:runId so the browser SPA can call
# this Worker directly. Leave it blank locally. To re-enable auth, re-wire
# `middlewares/require-api-key.ts` in app.ts + the workflow `runs` export.
# The eval harness still reads it from the AGENT_API_KEY environment variable.
AGENT_API_KEY=

# Sillage workspace key (`sk_live_...`), sent as a static `Authorization: Bearer`
# to the Sillage MCP server (https://api.getsillage.com/api/mcp/v2). Generate at
# https://www.getsillage.com/app/settings/api-keys. Optional: when unset, the
# orchestrator runs without the Sillage read tools. One key = one workspace.
# Production: `wrangler secret put SILLAGE_API_KEY`.
SILLAGE_API_KEY=

# Cloudflare AI Gateway authorization token — a Cloudflare API token with the
# AI Gateway "Run" permission. Sent as `cf-aig-authorization: Bearer <token>` to
# authenticate the orchestrator's Claude Opus 4.8 calls to the gateway (see
# src/providers/anthropic-gateway.ts). REQUIRED for the orchestrator: the
# gateway holds the Anthropic credentials (BYOK stored key or Unified Billing
# credits), so no Anthropic API key is needed here. Create the token at
# https://dash.cloudflare.com/profile/api-tokens and enable BYOK/credits on the
# gateway. Production: `wrangler secret put CF_AIG_TOKEN`.
CF_AIG_TOKEN=

# FullEnrich API key, sent as a static `Authorization: Bearer` to
# https://app.fullenrich.com/api/v1/contact/enrich/bulk by the
# `enrich_contact` tool (src/tools/full-enrich.ts). Generate at
# https://app.fullenrich.com/app/settings/api. Optional: when unset, the
# `contact_enricher` subagent cannot enrich contacts and reports so plainly.
# Production: `wrangler secret put FULLENRICH_API_KEY`.
FULLENRICH_API_KEY=

# Optional — unused in this app. All Claude models (Opus orchestrator, Sonnet
# specialists) route through AI Gateway with CF_AIG_TOKEN instead.
# Production: `wrangler secret put ANTHROPIC_API_KEY`.
ANTHROPIC_API_KEY=

# Workers AI inference (subagents + compaction) runs through the `AI` binding
# under the Worker's own account — no key needed. The non-secret `AI_GATEWAY_ID`
# and `CF_ACCOUNT_ID` vars live in wrangler.jsonc.
