{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "worker-agent",
  "account_id": "b664c6731df8a734cb99254f1991e102",
  "compatibility_date": "2026-06-01",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "placement": {
    "mode": "smart"
  },
  "dev": {
    "port": 8788,
    "inspector_port": 0
  },
  "send_metrics": false,
  "ai": {
    "binding": "AI",
    "remote": true
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": [
        "FlueRegistry",
        "FlueOrchestratorAgent"
      ]
    },
    {
      "tag": "v2",
      "new_sqlite_classes": [
        "FlueSampleAnswerWorkflow"
      ]
    },
    {
      "tag": "v3",
      "new_sqlite_classes": [
        "FlueEnrichContactsWorkflow"
      ]
    }
  ],
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },
  "kv_namespaces": [
    {
      "binding": "IDEMPOTENCY_KV",
      "id": "d98720f3dd544e6fa52321411bf2ca67"
    }
  ],
  "services": [
    {
      "binding": "DNS_WORKER",
      "service": "worker-dns"
    }
  ],
  "vars": {
    "ENVIRONMENT": "production",
    "AI_GATEWAY_ID": "default",
    "CF_ACCOUNT_ID": "b664c6731df8a734cb99254f1991e102",
    "WEB_APP_ORIGIN": "http://localhost:5174"
  },
  "main": ".flue-vite/_entry.ts",
  "durable_objects": {
    "bindings": [
      {
        "name": "FLUE_ORCHESTRATOR_AGENT",
        "class_name": "FlueOrchestratorAgent"
      },
      {
        "name": "FLUE_ENRICH_CONTACTS_WORKFLOW",
        "class_name": "FlueEnrichContactsWorkflow"
      },
      {
        "name": "FLUE_SAMPLE_ANSWER_WORKFLOW",
        "class_name": "FlueSampleAnswerWorkflow"
      },
      {
        "name": "FLUE_REGISTRY",
        "class_name": "FlueRegistry"
      }
    ]
  }
}